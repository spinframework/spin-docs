{{! This adds the HTML head section and the beginning of the body. See content_top.hbs. }}
{{> content_top }}

<main class="container is-fullwidth is-widescreen page-wrap">
    <div class="columns">

        {{! This adds the sidebar }}
        <div class="menu-wrap is-narrow is-fixed-desktop" id="docsMenu">
            <aside class="menu">
                {{! This adds the version selector }}
                <select class="version-dropdown"
                    onchange="this.options[this.selectedIndex].value && (window.location = this.options[this.selectedIndex].value);">
                    <option value="/v3/index" {{#if (active_project request.spin-full-url "/v3/" )}} selected {{/if}}>
                        Spin v3.x</option>
                    <option value="/v2/index" {{#if (active_project request.spin-full-url "/v2/" )}} selected {{/if}}>
                        Spin v2.x</option>
                    <option value="/v1/index" {{#if (active_project request.spin-full-url "/v1/" )}} selected {{/if}}>
                        Spin v1.x</option>
                    <option value="/v4/index" {{#if (active_project request.spin-full-url "/v4/" )}} selected {{/if}}>
                        Spin v4.x (Preview)</option>
                </select>

                {{#if (active_project request.spin-full-url "/v1/")}}
                    {{> sidebar_v1 }}
                {{else}}
                    {{#if (active_project request.spin-full-url "/v2/")}}
                        {{> sidebar_v2 }}
                    {{else}}
                        {{#if (active_project request.spin-full-url "/v4/")}}
                            {{> sidebar_v4 }}
                        {{else}}
                            {{> sidebar_v3 }}
                        {{/if}}
                    {{/if}}
                {{/if}}
            </aside>
        </div>

        <article class="column content content-docs content-docs-wide">
            <section id="type">
                <h1 class="blog-post-title border-bottom">{{page.head.title}}</h1>

                {{{page.body}}}

            </section>

            {{> content_footer }}
        </article>

    </div>
</main>


{{! This closes the body. See content_bottom.hbs. }}
{{> content_bottom }}

</body>
</html>
